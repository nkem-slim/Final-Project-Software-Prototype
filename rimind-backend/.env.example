NODE_ENV=development
PORT=4000

# PostgreSQL (AWS RDS in production)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public

# JWT — use long random strings in production (min 16 chars)
JWT_ACCESS_SECRET=your-access-secret-min-16-characters
JWT_REFRESH_SECRET=your-refresh-secret-min-16-characters
JWT_ACCESS_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# bcrypt salt rounds (SRS: minimum 12)
BCRYPT_ROUNDS=12

# Sprint 4: AI Virtual Doctor (Claude)
AI_PROVIDER=anthropic

ANTHROPIC_API_KEY=your_anthropic_api_key_here
AI_MODEL_ANTHROPIC=claude-haiku-4-5

# Sprint 3: SMS/USSD (Africa's Talking)
# Get credentials from https://account.africastalking.com — sandbox for testing
# AFRICAS_TALKING_API_KEY=your_api_key
# AFRICAS_TALKING_USERNAME=sandbox (or your username)
# AFRICAS_TALKING_BASE_URL=https://api.sandbox.africastalking.com
# SMS_SENDER_ID=optional_sender_id
# USSD: configure callback URL to https://your-domain/api/ussd
